{
  "cli": {
    "version": ">= 10.0.0"
  },
  "build": {
    "preview": {
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_LANG": "es" }
    },
    "preview-en": {
      "android": { "buildType": "apk" },
      "env": { "EXPO_PUBLIC_LANG": "en" }
    },
    "production": {
      "android": { "buildType": "app-bundle" },
      "env": { "EXPO_PUBLIC_LANG": "es" }
    },
    "production-en": {
      "android": { "buildType": "app-bundle" },
      "env": { "EXPO_PUBLIC_LANG": "en" }
    }
  },
  "submit": {
    "production": {}
  }
}
